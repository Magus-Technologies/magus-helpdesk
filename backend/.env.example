# ============================================================
# MAGUS HELP DESK — Variables de entorno
# Copiar a .env y completar con valores reales
# ============================================================

NODE_ENV=production
PORT=4000

# ── Base de datos PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=magus_helpdesk
DB_USER=magus_user
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# ── JWT ──
JWT_SECRET=TU_JWT_SECRET_MUY_LARGO_Y_SEGURO_MINIMO_32_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=soporte@magus-ecommerce.com
SMTP_PASS=TU_APP_PASSWORD_GMAIL
EMAIL_FROM=Magus Help Desk <soporte@magus-ecommerce.com>

# ── Empresa ──
EMPRESA_NOMBRE=Magus Help Desk

# ── Archivos ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=15

# ── Frontend / CORS ──
FRONTEND_URL=https://magus-ecommerce.com

# ── Tenant por defecto ──
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── WhatsApp Web (OPCIONAL) ──
# Poner true para activar. Requiere: npm install whatsapp-web.js qrcode-terminal
# Y Chromium: sudo apt install chromium-browser
WHATSAPP_ENABLED=false

# Ruta a Chromium si no está en PATH estándar (dejar vacío para autodetectar)
# CHROMIUM_PATH=/usr/bin/chromium-browser

# ────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE GMAIL:
# 1. Ir a myaccount.google.com → Seguridad → Verificación en 2 pasos (activar)
# 2. Ir a myaccount.google.com → Seguridad → Contraseñas de aplicaciones
# 3. Crear contraseña para "Correo" → copiar los 16 caracteres como SMTP_PASS
#
# CONFIGURACIÓN DE WHATSAPP:
# 1. Instalar: npm install whatsapp-web.js qrcode-terminal
# 2. Instalar Chromium: sudo apt install chromium-browser
# 3. Poner WHATSAPP_ENABLED=true
# 4. Reiniciar el servidor: pm2 restart magus-helpdesk
# 5. Ver QR en los logs: pm2 logs magus-helpdesk
# 6. Escanear con el WhatsApp del número de soporte
# 7. O acceder al QR desde el panel Admin → Configuración → WhatsApp
# ────────────────────────────────────────────────────────────
